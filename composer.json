{
    "name":  "elavora/api-cache-apcu",
    "description":  "Adapter APCu opcional para cache no framework Elavora",
    "type":  "library",
    "license":  "MIT",
    "require":  {
                    "php":  "\u003e=8.1",
                    "ext-apcu":  "*",
                    "elavora/api-framework":  "^0.3.1 || ^0.4.0"
                },
    "autoload":  {
                     "psr-4":  {
                                   "Elavora\\Api\\Extension\\CacheApcu\\":  "src/"
                               }
                 },
    "require-dev":  {
                        "phpunit/phpunit":  "^10.5 || ^11.0 || ^12.0"
                    },
    "scripts":  {
                    "test":  "@php -d apc.enable_cli=1 vendor/bin/phpunit -c phpunit.xml"
                },
    "extra":  {
                  "branch-alias":  {
                                       "dev-main":  "0.1-dev"
                                   }
              }
}
